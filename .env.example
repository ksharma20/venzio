# Venzio environment variables
# Copy this file and fill in values before running

# Leave empty for SQLite (local dev).
# turso provides this as TURSO_DATABASE_URL — copy that value here.
# TURSO_AUTH_TOKEN="eyXX.eyXX"
# TURSO_DATABASE_URL="libsql://venzio-db-xxxxxxxxx.turso.io"

# Random 32+ character string — generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key

# From resend.com (free tier)
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=onboarding@venzio.ai

# App base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000